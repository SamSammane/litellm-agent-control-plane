FROM node:22-slim

# Minimal local-dev image — no repo cloning, no semgrep/gitleaks.
# Just runs the harness server in an isolated environment so Claude Code
# doesn't pick up the host's ~/.claude config (hooks, plugins, memory).

WORKDIR /app

COPY harnesses/claude-agent-sdk/package*.json ./
RUN npm ci --omit=dev --legacy-peer-deps

COPY harnesses/claude-agent-sdk/dist/ ./dist/

ENV PORT=4096
EXPOSE 4096

CMD ["node", "dist/server.js"]
